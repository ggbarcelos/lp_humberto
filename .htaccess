# ─── Atenção: copie este conteúdo para o .htaccess da RAIZ do WordPress ───
# (NÃO dentro da pasta /lp/, mas sim na pasta pública do seu domínio)

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Exceção para a pasta lp
RewriteCond %{REQUEST_URI} ^/lp/
RewriteRule .* - [L]

# Regras padrão do WordPress
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress
